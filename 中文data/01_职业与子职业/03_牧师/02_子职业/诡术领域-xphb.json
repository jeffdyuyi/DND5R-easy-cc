              ]
            },
            {
              "ENG_name": "Healing Illusion",
              "name": "治愈幻象",
              "type": "entries",
              "entries": [
                "当幻象消失时，你或你选择的 5 尺内的一名生物恢复等同于你牧师等级的{@variantrule 生命值|XPHB}。"
              ]
            }
          ]
        }
      ]
    }
