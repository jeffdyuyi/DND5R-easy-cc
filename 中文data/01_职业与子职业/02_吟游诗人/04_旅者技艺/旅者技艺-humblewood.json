    {
      "ENG_name": "Acrobatics Lessons",
      "name": "反射闪避教程",
      "source": "HumblewoodCampaignSetting",
      "page": 36,
      "featureType": [
        "TT"
      ],
      "consumes": {
        "ENG_name": "Bardic Inspiration",
        "name": "吟游诗人激励",
        "amount": 1
      },
      "entries": [
        "一名狡猾的游荡者曾经给予了你一些关于闪躲与避险的指导。当你或你周围60尺范围内的一个盟友进行一次敏捷豁免时，你可以消耗一次诗人激励的使用次数，投掷你的诗人激励骰，并将骰值加入到那次豁免检定上。盟友必须可以听见你或看见你才能受益于此特性。",
        "达到第6级之后，豁免成功时，如果此次豁免的效应是一次\"豁免成功只受到半数伤害\"的效应，那么技艺目标豁免成功将不受任何伤害。",
        "达到第14级之后，即使技艺目标的豁免失败，它所受的伤害也会减半。"
      ],
      "foundryActivities": [
        {
          "activation": {
            "type": "",
            "condition": "当你或一个盟友进行敏捷豁免检定时"
          },
          "consumption": {
            "targets": [
              {
                "type": "itemUses",
                "target": {
                  "consumes": {
                    "name": "Bardic Inspiration"
                  }
                },
                "value": 1
              }
            ]
          },
          "roll": {
            "ENG_name": "Add to the Saving Throw",
            "name": "添加到豁免检定",
            "formula": "1@scale.bard.inspiration"
          },
          "type": "utility"
        }
      ]
    },
