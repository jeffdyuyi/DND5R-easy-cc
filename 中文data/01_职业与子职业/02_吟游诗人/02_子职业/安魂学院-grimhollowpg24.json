          ]
        },
        {
          "ENG_name": "Offense",
          "name": "进攻",
          "type": "entries",
          "entries": [
            "在该生物以攻击检定命中目标后，该生物可以掷一次诗人激励骰并将掷出的数值作为此次攻击的额外暗蚀伤害。"
          ]
        }
      ]
    },
    {
      "ENG_name": "Stir the Bones",
      "name": "唤醒骸骨",
      "source": "GrimHollowPG24",
      "page": 66,
      "className": "吟游诗人",
