                        "name": "圣武士",
                        "source": "PHB",
                        "definedInSource": "IllriggerRevised"
                    }
                ]
            }
        },
        {
            "ENG_name": "Hell's Lash",
            "name": "狱之笞",
            "source": "IllriggerRevised",
            "level": 1,
            "school": "V",
            "time": [
                {
                    "number": 1,
                    "unit": "动作"
                }
            ],
            "range": {
