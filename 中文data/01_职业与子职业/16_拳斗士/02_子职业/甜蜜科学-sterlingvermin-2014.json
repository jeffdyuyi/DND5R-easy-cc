    },
    {
      "ENG_name": "Bare Knuckle Boxer",
      "name": "裸拳拳手",
      "entries": [
        "从你在3级选择这个搏击俱乐部开始，你的徒手打击在d20掷出19或20时会造成重击。"
      ],
      "source": "SterlingVermin",
      "className": "拳斗士",
