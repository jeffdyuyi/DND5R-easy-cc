            [
              "5",
              "{@spell 次等复原术|XPHB}, {@spell 守护之链|XPHB}"
            ],
            [
              "9",
              "{@spell 希望信标|XPHB}, {@spell 防护能量|XPHB}"
            ],
            [
              "13",
