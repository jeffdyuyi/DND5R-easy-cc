      "subclassSource": "GriffonsSaddlebag2",
      "level": 3,
      "header": 1,
      "entries": [
        "饮咒之誓致力于肃清世间的叛道法师（如巫妖或是秘教徒），以守护无辜者免受邪恶魔法的荼毒。立下此誓的圣武士坚信须维系凡俗力量与超凡力量（包括自身）之间的平衡。这些圣武士足智多谋，牢记死亡之突然与力量之权责，遇事常常选用凡俗手段而非魔法。虽行事审慎，这些平衡守护者却堪称典范级的奥术大师，对世间魔法流动的感知敏锐程度，不逊于最顶尖的术士。",
        {
          "type": "refSubclassFeature",
          "subclassFeature": "饮咒之信条|圣武士|PHB|饮咒|GriffonsSaddlebag2|3|GriffonsSaddlebag2"
        },
        {
          "type": "refSubclassFeature",
          "subclassFeature": "圣誓法术|圣武士|PHB|饮咒|GriffonsSaddlebag2|3|GriffonsSaddlebag2"
        },
        {
          "type": "refSubclassFeature",
          "subclassFeature": "引导神力|圣武士|PHB|饮咒|GriffonsSaddlebag2|3|GriffonsSaddlebag2"
        },
        {
          "type": "refSubclassFeature",
          "subclassFeature": "附赠熟练项|圣武士|PHB|饮咒|GriffonsSaddlebag2|3|GriffonsSaddlebag2"
        }
      ]
    },
    {
      "ENG_name": "Bonus Proficiency",
      "name": "附赠熟练项",
      "source": "GriffonsSaddlebag2",
      "page": 221,
      "className": "圣武士",
      "classSource": "PHB",
      "subclassShortName": "饮咒",
