              ]
            },
            {
              "ENG_name": "Violent Strikes",
              "name": "暴力猛击",
              "type": "item",
              "entries": [
                "当你用武器或{@variantrule 徒手打击|XPHB}命中一个生物时，你可以对目标造成额外的{@damage 1d6}暗蚀伤害。"
              ]
            }
          ]
        }
      ]
    },
    {
      "ENG_name": "Circle of Blood",
