      "ENG_name": "Bonus Cantrip",
      "source": "PHB",
      "page": 67,
      "className": "德鲁伊",
      "classSource": "PHB",
      "subclassShortName": "大地",
      "subclassSource": "PHB",
      "level": 2,
      "entries": [
        "第2级你选择此结社时，你获得一个额外的德鲁伊戏法。"
      ]
