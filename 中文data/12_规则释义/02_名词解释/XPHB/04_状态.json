            ]
          },
          {
            "ENG_name": "Removing Exhaustion Levels",
            "name": "移除力竭等级",
            "type": "entries",
            "entries": [
              "你可以依靠完成{@variantrule 长休|XPHB}来降低 1 级力竭等级。当你力竭等级降至 0 时，此状态结束。"
            ]
