    ],
    "skillProficiencies": [
      {
        "perception": true
      }
    ],
    "entries": [
      {
        "ENG_name": "Age",
        "name": "年龄",
        "type": "entries",
        "entries": [
          "尽管精灵的生理成熟速度和人类差不多，但成年的精灵除生理成熟外，还必须拥有成熟的处世经验。一般而言，精灵一般在100岁前后宣布成年，寿命可达750岁。"
        ]
      },
      {
        "ENG_name": "Alignment",
        "name": "阵营",
        "type": "entries",
        "entries": [
          "精灵热爱自由、多样性和自我表达，因此他们强烈倾向于混乱的温和方面。他们珍视并保护他人的自由以及自己的自由，他们通常比不是善良的要多。"
        ]
      },
      {
        "ENG_name": "Size",
        "name": "体型",
        "type": "entries",
        "entries": [
          "精灵中有的身高低于5尺，而有的则甚至超过6尺。他们身材纤细，属于中型体型。"
        ]
      },
      {
        "ENG_name": "Darkvision",
        "name": "黑暗视觉",
        "entries": [
          "精灵早已适应了在幽暗的森林中和夜晚的天空下视物。你在黑暗和微光光照下拥有超常的视力。在微光光照下，你身边60尺内可以视为等同于明亮光照。而在黑暗中，该范围内可视为等同于微光光照。你无法在黑暗中分辨颜色，只能看到有灰度的黑白画面。"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Keen Senses",
        "name": "敏锐感官",
        "entries": [
          "你拥有{@skill 察觉}技能的熟练项。"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Elf Weapon Training",
        "name": "精灵武器训练",
        "entries": [
          "你拥有{@item 长剑|PHB}、{@item 短剑|PHB}、{@item 短弓|PHB}和{@item 长弓|PHB}的熟练项。"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Fey Ancestry",
        "name": "妖精血统",
        "entries": [
          "你进行对抗{@condition 魅惑}的豁免时具有优势，并且不会因魔法效应而陷入睡眠。"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Trance",
        "name": "出神",
        "entries": [
          "精灵不需要睡眠。他们会在需要休息时陷入持续4个小时的半清醒深度冥想中（通用语中描述此状态的词是\"出神Trance\"）。冥想时精灵也会做梦，这种梦其实是反应多年来现实生活的思维活动。以这种方式休息后，你获得人类睡眠8小时的全部益处。",
          "{@note 如果你在长休期间进行冥想，你可以在4小时后就完成长休。你仍然会遵照长休的所有规则；只有长休的时间发生了变化。}"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Languages",
        "name": "语言",
        "entries": [
          "你能够说、读、写通用语和精灵语。精灵语如流体般流畅，有着微妙的语调变化和复杂的语法结构。精灵文学十分丰富多彩，他们的诗歌在其他种族里也享有很高的评价。许多吟游诗人都会学习精灵语，并将其韵律运用在他们自己的诗作中。"
        ],
        "type": "entries"
      },
      {
        "ENG_name": "Elf Culture",
        "name": "精灵文化",
        "entries": [
          "卡德加什的精灵不将自己组织成国家或部落。尽管如此，他们在自己的族群中识别出三种不同的文化群体——尽管实际上，这些群体更像是对社会其他部分以及使用技术的态度或立场。选择其中一种文化。"
        ],
        "type": "entries"
      }
    ],
    "subraces": [
      {
        "name": "比什塔哈和蒂厄赫",
        "ENG_name": "Bishatar and Tirahar",
        "source": "PSK",
        "page": 21,
        "speed": 35,
        "entries": [
          {
            "ENG_name": "Fleet of Foot",
            "name": "轻捷步伐",
            "entries": [
              "你的地面速度增加到35尺。"
            ],
            "type": "entries",
            "data": {
              "overwrite": "精灵文化"
            }
          },
          {
            "ENG_name": "Mask of the Wild",
            "name": "荒野隐蔽",
            "entries": [
              "即便你只处于轻度遮蔽的状态，只要这一轻度遮蔽由树丛，大雨，落雪，雾气或其他自然现象提供，你也可以进行躲藏。"
            ],
            "type": "entries"
          }
        ],
        "fluff": {
          "entries": [
            {
              "type": "quote",
              "entries": [
                "万物相连，以太流贯其中。"
              ]
            },
            "以太在世界中的流动是可见且明显的，当它以发光的河流横贯天空，扫过雕刻的平原，或通过巨大的城市管道倾泻时。但卡德拉什的精灵们与整个平面上以太的流动——无论是可见的还是不可见的——以及它如何微妙地渗透并影响所有生命的独特和谐一致。他们称这种流动为大导管，并相信真正理解它的唯一方式就是成为它的一部分，同时塑造它并被它塑造。",
            "正是由于这种敏感性，精灵们对其他生物有着深刻的联系。他们深入地与周围的世界互动，无论是对自然系统还是社交互动都感到愉悦。他们喜欢探索自然与社会的相互联系，观察以太从自然流向发明，从一个人流向另一个人，从身体流向心灵和心脏。",
            "精灵与自然和技术和谐共存。他们相信自然是启发技术的源泉：每一件人造物品都是自然法则和原则的表达，并且捕捉到了以太流动的一个元素，形成了一种微观系统。反过来，技术可以培育自然世界，帮助生命在原本不可能的地方和方式中生长和繁荣。"
          ],
